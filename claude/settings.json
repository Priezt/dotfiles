{
  "permissions": {
    "allowedTools": [
      "Read",
      "Write",
      "Bash(git status)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(ls:*)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(cargo:*)"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq .message | cc-alert"
          }
        ]
      }
    ]
  }
}
