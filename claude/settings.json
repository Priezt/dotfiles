{
  "permissions": {
    "allowedTools": [
      "Read",
      "Write",
	  "Bash"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq .message | cc-alert"
          }
        ]
      }
    ]
  }
}
